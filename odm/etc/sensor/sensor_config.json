{
	"20307": {
		"platform_config": {
			"sensor_arch": "mtk_sensor_arch_2_0"
		},
		"sensor_config": {
			"android.sensor.accelerometer": {
				"type": 1,
				"support": "true",
				"module": "sc7a20|lis2hh12",
				"sc7a20": {
					"mode": "batch_cali|factory_cali",
					"offset_x": 0.0,
					"offset_y": 0.0,
					"offset_z": 0.0
				},
				"lis2hh12": {
					"mode": "batch_cali|factory_cali",
					"offset_x": 0.0,
					"offset_y": 0.0,
					"offset_z": 0.0
				}
			},
			"android.sensor.magnetic_field": {
				"type": 2,
				"support": "true",
				"module": "akm09918|mmc5603",
				"akm09918":{
					"mode":"batch_cali"
				},
				"mmc5603":{
					"mode":"batch_cali"
				}
			},
			"android.sensor.gyroscope": {
				"type": 4,
				"support": "true",
				"module": "bmi160|lsm6dsm",
				"bmi160": {
					"mode": "batch_cali|factory_cali",
					"radian_threshold": 0.05,
					"offset_x": 0.0,
					"offset_y": 0.0,
					"offset_z": 0.0
				},
				"lsm6dsm": {
					"mode": "batch_cali|factory_cali",
					"radian_threshold": 0.05,
					"offset_x": 0.0,
					"offset_y": 0.0,
					"offset_z": 0.0
				}
			},
			"android.sensor.proximity": {
				"type": 8,
				"support": "true",
				"module": "stk33502|mn78911",
				"stk33502": {
					"mode":"ignore_mean|micro_gap|factory_cali",
					"delta_threshold":150,
					"ps0_offset": 0,
					"ps0_distance_delta": 110,
					"ps1_offset": 0,
					"ps1_distance_delta": 0
				},
				"mn78911":{
					"mode": "ignore_mean|micro_gap|factory_cali",
					"delta_threshold": 150,
					"ps0_offset": 0,
					"ps0_distance_delta": 110,
					"ps1_offset": 0,
					"ps1_distance_delta": 0
				}
			},
			"android.sensor.step_counter": {
				"type": 19,
				"support": "true"
			},
			"android.sensor.light": {
				"type": 5,
				"support": "true",
				"module": "stk33502|mn78911",
				"stk33502":{
					"mode":"factory_cali|micro_gap",
					"cali_para": 1000
				},
				"mn78911":{
					"mode":"factory_cali|micro_gap",
					"cali_para": 1000
				}
			},
			"android.sensor.wise_light": {
				"type": 65627,
				"support": "false",
				"module": "tcs3701|stk32600",
				"tcs3701": {
					"mode":"factory_cali",
					"cali_para": 1000,
					"R_MAX": 0,
					"G_MAX": 0,
					"B_MAX": 0,
					"W_MAX": 0
				},
				"stk32600":{
					"mode": "factory_cali",
					"cali_para": 1000,
					"R_MAX": 0,
					"G_MAX": 0,
					"B_MAX": 0,
					"W_MAX": 0
				}
			}
		}
